# ─── Application ──────────────────────────────────────────────────────────────
BASE_URL=https://api.yourbank.com
ENV=staging

# ─── Oracle DB ────────────────────────────────────────────────────────────────
ORACLE_DSN=localhost:1521/ORCL
ORACLE_USER=test_user
ORACLE_PASSWORD=your_password_here

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=banking_db
PG_USER=test_user
PG_PASSWORD=your_password_here

# ─── IBM DB2 ──────────────────────────────────────────────────────────────────
DB2_HOST=localhost
DB2_PORT=50000
DB2_DATABASE=BANKING
DB2_USER=test_user
DB2_PASSWORD=your_password_here

# ─── MCP / AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
MCP_SERVER_PORT=8765

# ─── Jira ─────────────────────────────────────────────────────────────────────
JIRA_URL=https://yourorg.atlassian.net
JIRA_USER=your_email@yourorg.com
JIRA_TOKEN=your_jira_token_here
JIRA_PROJECT=BFSI

# ─── Reporting ────────────────────────────────────────────────────────────────
ALLURE_RESULTS_DIR=reports/allure-results
